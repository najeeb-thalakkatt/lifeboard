rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ───────────────────────────────────────

    /// Returns true if the request is from an authenticated user.
    function isAuthenticated() {
      return request.auth != null;
    }

    /// Returns true if the requesting user is a member of the space.
    function isSpaceMember(spaceId) {
      return isAuthenticated() &&
        request.auth.uid in resource.data.members;
    }

    /// Returns true if the requesting user is a member of the space (for creates).
    function willBeSpaceMember(spaceId) {
      return isAuthenticated() &&
        request.auth.uid in request.resource.data.members;
    }

    /// Returns true if the user is joining the space (not yet a member, will be after update, with 'member' role).
    function isJoiningSpace() {
      return isAuthenticated() &&
        !(request.auth.uid in resource.data.members) &&
        request.auth.uid in request.resource.data.members &&
        request.resource.data.members[request.auth.uid].role == 'member';
    }

    // ── Users ─────────────────────────────────────────────────

    match /users/{userId} {
      // Any authenticated user can read user profiles (needed for showing
      // partner names/photos in shared spaces). User docs contain only
      // displayName, email, photoUrl, moodEmoji, spaceIds — nothing sensitive.
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if false; // No self-deletion via client
    }

    // ── Spaces ────────────────────────────────────────────────

    match /spaces/{spaceId} {
      // Any authenticated user can read spaces.
      // NOTE: This is required because joinSpace() queries by inviteCode, which
      // needs read access to non-member spaces. Firestore rules cannot inspect
      // query where-clauses. To fully restrict, move invite-code lookup to a
      // Cloud Function. Low-risk for this app: exposed data is space name,
      // member IDs, and invite code.
      allow read: if isAuthenticated();

      // Any authenticated user can create a space (they become the owner).
      allow create: if isAuthenticated() && willBeSpaceMember(spaceId);

      // Existing members can update, OR a new user can join (add themselves as 'member').
      allow update: if isSpaceMember(spaceId) || isJoiningSpace();

      // Only the owner can delete a space.
      allow delete: if isAuthenticated() &&
        resource.data.members[request.auth.uid].role == 'owner';

      // ── Boards (sub-collection) ─────────────────────────────
      match /boards/{boardId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/spaces/$(spaceId)).data.members;
        allow create, update: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/spaces/$(spaceId)).data.members;
        allow delete: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/spaces/$(spaceId)).data.members;
      }

      // ── Tasks (sub-collection) ──────────────────────────────
      match /tasks/{taskId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/spaces/$(spaceId)).data.members;
        allow create, update: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/spaces/$(spaceId)).data.members;
        allow delete: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/spaces/$(spaceId)).data.members;

        // ── Comments (sub-sub-collection) ───────────────────
        match /comments/{commentId} {
          allow read: if isAuthenticated() &&
            request.auth.uid in get(/databases/$(database)/documents/spaces/$(spaceId)).data.members;
          allow create: if isAuthenticated() &&
            request.auth.uid in get(/databases/$(database)/documents/spaces/$(spaceId)).data.members;
          // Only the comment author can update or delete their own comments.
          allow update, delete: if isAuthenticated() &&
            request.auth.uid in get(/databases/$(database)/documents/spaces/$(spaceId)).data.members &&
            resource.data.authorId == request.auth.uid;
        }
      }

      // ── Activity (sub-collection) ────────────────────────────
      match /activity/{activityId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/spaces/$(spaceId)).data.members;
        // Members can update reactions; create/delete only via Cloud Functions
        allow update: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/spaces/$(spaceId)).data.members;
        allow create, delete: if false;
      }
    }
  }
}
